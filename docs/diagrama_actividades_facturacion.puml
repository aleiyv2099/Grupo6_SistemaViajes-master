@startuml diagrama_actividades_facturacion
title Módulo de Facturación — Sistema de Viajes (Grupo 6)

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultFontSize 13
skinparam defaultFontName Arial
skinparam ArrowColor #555555
skinparam activityBackgroundColor #DDEEFF
skinparam activityBorderColor #3366AA
skinparam activityDiamondBackgroundColor #FFF5CC
skinparam activityDiamondBorderColor #CC9900

skinparam swimlane {
    TitleBackgroundColor #E8EAF6
    TitleFontColor #283593
    TitleFontStyle bold
    BorderColor #CCCCCC
}

' ═══════════════════════════════
'  EMITIR FACTURA
' ═══════════════════════════════
|#FFF9C4|Usuario|
start
:Selecciona un cliente;
:Elige método de pago\ny estado de factura;
:Clic en "Emitir Factura";

|#E3F2FD|Sistema|
if (¿Campos completos\ny hay reservas?) then (no)
    #FFCDD2:Aviso al usuario;
    stop
else (sí)
endif
:Calcula el monto total;
:Guarda la factura;
:Marca reservas como facturadas;
if (¿Guardado exitoso?) then (sí)
    #C8E6C9:"Factura registrada";
    :Limpia formulario y recarga tabla;
else (no)
    #FFCDD2:Muestra error y cancela;
    stop
endif

' ═══════════════════════════════
'  ANULAR FACTURA
' ═══════════════════════════════
|#FFF9C4|Usuario|
:Selecciona una factura\nen la tabla;
:Clic en "Anular";

|#E3F2FD|Sistema|
if (¿Confirma\nanulación?) then (sí)
    :Marca la factura\ncomo anulada;
    :Recarga la tabla;
else (no)
    :No hace nada;
endif

' ═══════════════════════════════
'  BUSCAR FACTURAS
' ═══════════════════════════════
|#FFF9C4|Usuario|
:Escribe en el campo\nde búsqueda;

|#E3F2FD|Sistema|
:Filtra por código,\nmétodo de pago o estado;
:Actualiza la tabla;
stop

@enduml
